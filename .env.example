# Copy this to .env and fill in your values.

# Local Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://sankofa:sankofa@localhost:5432/sankofa_showdown

# Set to 1 to force SSL (Railway sets this automatically via DATABASE_URL hostname)
# DB_SSL=1

# Public URL of the server — used by the frontend to build buzzer URLs & QR codes.
# Locally: leave blank (uses window.location.origin)
# ngrok:   VITE_ENDPOINT=https://sankofa.ngrok.app
# Railway: VITE_ENDPOINT=https://your-app.up.railway.app
VITE_ENDPOINT=
