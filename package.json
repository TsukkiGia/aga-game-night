{
  "name": "scorekeeping",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0 <23"
  },
  "scripts": {
    "start": "npm run build && node server.js",
    "dev": "concurrently -n \"server,vite\" -c \"yellow,cyan\" \"nodemon --watch server.js --env-file=.env server.js\" \"vite\"",
    "server": "nodemon --watch server.js --env-file=.env server.js",
    "test": "node --test",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "vite": "^6.4.1"
  }
}
